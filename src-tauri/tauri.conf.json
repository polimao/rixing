{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "日行",
  "version": "1.0.0",
  "identifier": "com.limao.rixing",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "日行",
        "width": 440,
        "height": 200,
        "minWidth": 340,
        "minHeight": 200,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "calendar",
        "title": "日历",
        "width": 380,
        "height": 400,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false,
        "url": "calendar.html"
      },
      {
        "label": "settings",
        "title": "日行设置",
        "width": 600,
        "height": 700,
        "resizable": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "url": "settings.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "resources": {
      "python/mrt2_bridge.py": "python/"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}